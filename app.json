{
  "expo": {
    "name": "VoxScore",
    "slug": "voxscore",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "voxscore",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0008"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gamechangerbuilds.voxscore"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0D0008"
      },
      "package": "com.gamechangerbuilds.voxscore"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "reactNativeReleaseLevel": "experimental"
          },
          "ios": {
            "reactNativeReleaseLevel": "experimental"
          }
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "game-changer-builds",
          "project": "voxscore"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
