# ============================================================
# VoxScore — Variables d'environnement
# Copier ce fichier en .env.local pour le développement
# Ne jamais commiter .env.local — voir .gitignore
# ============================================================
# Préfixe EXPO_PUBLIC_ = exposé côté client (bundle JS)
# Sans préfixe = server-side uniquement (Edge Functions Supabase)
# ============================================================

# ------------------------------------------------------------
# SUPABASE
# Dashboard : https://supabase.com/dashboard/project/<ref>/settings/api
# Région obligatoire : EU Frankfurt — non modifiable après création
# ------------------------------------------------------------
EXPO_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ...           # clé publique (RLS actif)
SUPABASE_SERVICE_ROLE_KEY=eyJ...               # ⚠️ server-side uniquement — Edge Functions

# ------------------------------------------------------------
# ANTHROPIC — Claude Sonnet (génération) + Claude Haiku (modération)
# Dashboard : https://console.anthropic.com/settings/keys
# Utilisé exclusivement dans les Supabase Edge Functions (server-side)
# ------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...

# ------------------------------------------------------------
# MISTRAL — Embeddings sémantiques (promesse↔vote)
# Dashboard : https://console.mistral.ai/api-keys
# Modèle : mistral-embed — dim. 1024 — server-side uniquement
# ⚠️ Ne jamais mélanger avec un autre modèle d'embeddings (espaces vectoriels incompatibles)
# ------------------------------------------------------------
MISTRAL_API_KEY=...

# ------------------------------------------------------------
# UPSTASH REDIS — Buffer votes Baromètre + rate limiting + cache scores
# Dashboard : https://console.upstash.com
# Dès V1 — obligatoire avant tout déploiement production
# ------------------------------------------------------------
UPSTASH_REDIS_REST_URL=https://<id>.upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# ------------------------------------------------------------
# ONESIGNAL — Push notifications (dès V1, remplace Expo Push)
# Dashboard : https://dashboard.onesignal.com/apps/<app_id>/settings/keys
# ⚠️ Ne jamais déployer Expo Push Notifications en production
# ------------------------------------------------------------
EXPO_PUBLIC_ONESIGNAL_APP_ID=...               # côté client (initialisation SDK)
ONESIGNAL_API_KEY=...                          # server-side uniquement (envoi ciblé)

# ------------------------------------------------------------
# SENTRY — Error tracking React Native
# Package : @sentry/react-native (ne pas utiliser sentry-expo, déprécié)
# Dashboard : https://sentry.io/settings/<org>/projects/<project>/keys/
# Plan gratuit : 5 000 erreurs/mois — suffisant MVP + V1
# ------------------------------------------------------------
EXPO_PUBLIC_SENTRY_DSN=https://...@o....ingest.sentry.io/...

# ------------------------------------------------------------
# POSTHOG — Analytics RGPD-compliant (hébergement EU Frankfurt)
# Dashboard : https://eu.posthog.com/project/settings
# Gratuit < 1M events/mois — activer dès le MVP
# ------------------------------------------------------------
EXPO_PUBLIC_POSTHOG_API_KEY=phc_...
EXPO_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ------------------------------------------------------------
# TWILIO — SMS OTP (Trust Ladder N2 — vote Baromètre)
# ⚠️ Configuré directement dans le Dashboard Supabase Auth
#    (Supabase > Auth > SMS Provider > Twilio)
#    Ces variables ne sont PAS utilisées dans le code applicatif
# Dashboard : https://console.twilio.com/us1/account/keys
# ------------------------------------------------------------
# TWILIO_ACCOUNT_SID=AC...      → dans Supabase Dashboard uniquement
# TWILIO_AUTH_TOKEN=...         → dans Supabase Dashboard uniquement
# TWILIO_PHONE_NUMBER=+33...    → dans Supabase Dashboard uniquement

# ------------------------------------------------------------
# API EXTERNES — Sources de données parlementaires (open data, sans clé)
# NosDéputés.fr : https://www.nosdeputes.fr/api
# LaFabriqueDelaLoi.fr : https://www.lafabriquedelaloi.fr/api
# Ces APIs sont publiques — aucune authentification requise
# ------------------------------------------------------------
# NOSDEPUTES_API_BASE_URL=https://www.nosdeputes.fr  # référence seulement
