      "accentLight":      "rgba(255,255,255,0.70)",
      "accentMedium":     "rgba(255,255,255,0.50)",
      "background":       "transparent",
      "surface":          "rgba(255,255,255,0.75)",
      "surfaceElevated":  "rgba(255,255,255,0.90)",
