  "components": {

    "GradientBackground": {
      "file": "components/common/GradientBackground.tsx",
      "description": "Fond dégradé 4 stops — wrapping global de toutes les screens",
      "usage": "<GradientBackground>{children}</GradientBackground>",
      "dependencies": ["expo-linear-gradient", "contexts/ThemeContext"],
      "props": { "children": "ReactNode" },
      "note": "Gère automatiquement light/dark via useTheme(). À utiliser sur toutes les screens."
    },

    "CoherenceRing": {
      "file": "components/common/CoherenceRing.tsx",
      "description": "Anneau SVG style Apple Watch — composant central des fiches élus",
      "usage": "<CoherenceRing score={78} size={120} strokeWidth={8} showLabel dark />",
      "dependencies": ["react-native-svg", "constants/colors"],
      "props": {
        "score":       "number (0-100) — requis",
        "size":        "number — défaut 80",
        "strokeWidth": "number — défaut 8",
        "showLabel":   "boolean — affiche 'Excellent/Bon/Moyen/Faible/Très faible'",
        "dark":        "boolean — texte blanc pour fond sombre"
      },
      "score_thresholds": {
        ">=70": { "color": "#00C87A", "label": "Bon/Excellent" },
        ">=40": { "color": "#FF8C00", "label": "Moyen/Faible" },
        "<40":  { "color": "#FF3355", "label": "Très faible" }
      },
      "label_thresholds": {
        ">=80": "Excellent",
        ">=70": "Bon",
        ">=55": "Moyen",
        ">=40": "Faible",
        "<40":  "Très faible"
      },
      "exports": ["default CoherenceRing", "getScoreColor(score)", "getScoreLabel(score)"],
      "note": "fontSize = size × 0.26 (score) et size × 0.14 (label /100) — responsive automatique"
    },

    "VoteBadge": {
      "file": "components/common/VoteBadge.tsx",
      "description": "Pastille vote avec border teinté — 3 tailles disponibles",
      "usage": "<VoteBadge vote='pour' size='md' />",
      "dependencies": ["constants/colors"],
      "props": {
        "vote": "'pour' | 'contre' | 'abstention' | 'absent'",
        "size": "'sm' | 'md' | 'lg' — défaut 'md'"
      },
      "variants": {
        "pour":       { "label": "POUR",        "bg": "#D0FAE8", "text": "#006640", "border": "#00C87A" },
        "contre":     { "label": "CONTRE",      "bg": "#FFE5EA", "text": "#8C001E", "border": "#FF3355" },
        "abstention": { "label": "ABSTENTION",  "bg": "#FFF0D9", "text": "#7A3E00", "border": "#FF8C00" },
        "absent":     { "label": "ABSENT",      "bg": "#EDF2F7", "text": "#A0AEC0", "border": "#A0AEC0" }
      },
      "sizes": {
        "sm": { "fontSize": 9,  "px": 6,  "py": 3, "radius": 5 },
        "md": { "fontSize": 10, "px": 8,  "py": 4, "radius": 6 },
        "lg": { "fontSize": 12, "px": 12, "py": 5, "radius": 8 }
      },
      "note": "border = couleur principale + opacité 40 (hex '40' = 25%)"
    },

    "CoherenceBadge": {
      "file": "components/common/CoherenceBadge.tsx",
      "description": "Badge texte avec icône Lucide — 3 états de cohérence",
      "usage": "<CoherenceBadge coherence='respected' showIcon />",
      "dependencies": ["lucide-react-native", "constants/colors"],
      "props": {
        "coherence": "'respected' | 'broken' | 'partial'",
        "showIcon":  "boolean — défaut true"
      },
      "variants": {
        "respected": { "label": "Promesse tenue",         "bg": "#D0FAE8", "color": "#00C87A", "icon": "CheckCircle" },
        "broken":    { "label": "Promesse brisée",        "bg": "#FFE5EA", "color": "#FF3355", "icon": "XCircle"    },
        "partial":   { "label": "Partiellement tenue",    "bg": "#FFF0D9", "color": "#FF8C00", "icon": "AlertCircle"}
      }
    },

    "CategoryBadge": {
      "file": "components/common/CategoryBadge.tsx",
      "description": "Badge couleur par catégorie thématique — couleurs indépendantes du thème",
      "usage": "<CategoryBadge category='Environnement' />",
      "categories": {
        "Social":        { "bg": "#F0F4FF", "color": "#1E4FD8" },
        "Economie":      { "bg": "#FFF7E6", "color": "#B45309" },
        "Immigration":   { "bg": "#FFF0F3", "color": "#BE123C" },
        "Environnement": { "bg": "#ECFDF5", "color": "#047857" },
        "Justice":       { "bg": "#EFF6FF", "color": "#1D4ED8" },
        "Numerique":     { "bg": "#F0FEFF", "color": "#0E7490" },
        "Sante":         { "bg": "#FDF4FF", "color": "#9333EA" },
        "Education":     { "bg": "#FFF7ED", "color": "#C2410C" },
        "fallback":      { "bg": "#F1F5F9", "color": "#64748B" }
      },
      "note": "À étendre pour VoxScore — ajouter : Securite, Logement, Agriculture, Energie, Transports"
    },

    "DeputyCard": {
      "file": "components/DeputyCard.tsx",
      "description": "Carte député complète avec photo, parti, score, stats — mode compact disponible",
      "usage": "<DeputyCard deputy={deputy} compact={false} />",
      "dependencies": ["expo-router", "lucide-react-native", "CoherenceRing", "constants/colors", "contexts/ThemeContext"],
      "props": {
        "deputy":  "Deputy (type database)",
        "compact": "boolean — défaut false. Si true : masque le footer stats"
      },
      "features": [
        "Navigation auto vers /depute/{id} via expo-router",
        "Photo avec fallback initiales (prénom[0] + nom[0])",
        "Point de couleur parti en badge sur la photo",
        "Badge parti coloré dynamique",
        "CoherenceRing intégré (size 66 normal, 58 compact)",
        "Footer : nb mandats + taux absences + score CTA (masqué en compact)",
        "Absences > 20% affichées en rouge automatiquement"
      ],
      "type_deputy_fields": [
        "id", "first_name", "name", "photo_url", "department",
        "coherence_score", "mandates_count", "absences_rate",
        "party.color", "party.short_name"
      ]
    },

    "LawCard": {
      "file": "components/LawCard.tsx",
      "description": "Carte loi expandable avec impacts, barre de votes, coût estimé",
      "usage": "<LawCard law={law} showDetails={false} />",
      "dependencies": ["expo-router", "lucide-react-native", "CategoryBadge", "constants/colors", "contexts/ThemeContext"],
      "props": {
        "law":         "Law (type database)",
        "showDetails": "boolean — défaut false. Contrôle état initial expanded"
      },
      "features": [
        "Navigation auto vers /loi/{id} via expo-router",
        "Badge catégorie + badge résultat (Adoptée/Rejetée/En cours)",
        "Titre court + description expandable (2 lignes par défaut)",
        "Section impacts positifs (TrendingUp vert)",
        "Section impacts négatifs (TrendingDown rouge)",
        "Coût estimé si disponible",
        "Barre de votes colorée Pour/Contre/Abstention",
        "Bouton Voir le détail / Réduire"
      ],
      "vote_results": {
        "adopted":  { "label": "Adoptée",   "bg": "keptLight",    "color": "kept"    },
        "rejected": { "label": "Rejetée",   "bg": "brokenLight",  "color": "broken"  },
        "pending":  { "label": "En cours",  "bg": "partialLight", "color": "partial" }
      },
      "type_law_fields": [
        "id", "title_short", "description_simple", "category", "vote_result",
        "vote_date", "positive_impacts[]", "negative_impacts[]",
        "estimated_cost", "pour_count", "contre_count", "abstention_count"
      ]
    },

    "CommunePicker": {
      "file": "components/CommunePicker.tsx",
      "description": "Modal de sélection de commune par code postal — connecté Supabase",
      "usage": "<CommunePicker visible postalCode='75001' communes={[]} onSelect={fn} onClose={fn} />",
      "dependencies": ["supabase", "lucide-react-native", "react-native-safe-area-context", "contexts/ThemeContext"],
      "features": [
        "Modal slide-up (pageSheet)",
        "Filtre de recherche si >5 communes",
        "FlatList optimisée avec keyExtractor",
        "Affiche département + numéro de circonscription",
        "Reset filtre à chaque ouverture"
      ],
      "type_PostalCodeCommune": {
        "code":                 "string",
        "commune_name":         "string",
        "department_name":      "string",
        "constituency_number":  "number",
        "deputy_id":            "string"
      },
      "note_voxscore": "À adapter pour VoxScore — renommer deputy_id en politician_id, ajouter chamber"
    }
  },

