{
  "meta": {
    "project": "VoxScore",
    "source": "Hemicycle V1 — bolt.new — analyse complète du 23/03/2026",
    "stack_confirmed": "React Native + Expo + expo-linear-gradient + react-native-svg + lucide-react-native + expo-router + Supabase",
    "instructions": "Source de vérité design absolue pour VoxScore V2. Ne jamais hardcoder couleurs ou tailles. Toujours importer depuis ce fichier ou constants/colors.ts."
  },

  "stack": {
    "framework":    "React Native (Expo)",
    "router":       "expo-router",
    "gradient":     "expo-linear-gradient",
    "svg":          "react-native-svg",
    "icons":        "lucide-react-native",
    "backend":      "Supabase (@supabase/supabase-js)",
    "theme":        "Context API — useTheme() → colors object (light/dark auto)",
    "safe_area":    "react-native-safe-area-context",
    "note":         "Stack 100% compatible VoxScore V2 — aucune migration nécessaire"
  },

