  "gradients": {
    "main_light": {
      "colors":    ["#FF3870", "#FF7A5A", "#FFB89A", "#FFF0E8"],
      "start":     { "x": 0, "y": 0 },
      "end":       { "x": 0.4, "y": 1 },
      "note":      "4 stops — dégradé rose → saumon → pêche → blanc cassé"
    },
    "main_dark": {
      "colors":    ["#4A0A20", "#2D0A1A", "#1A0810", "#0F050A"],
      "start":     { "x": 0, "y": 0 },
      "end":       { "x": 0.4, "y": 1 },
      "note":      "4 stops — bordeaux profond vers noir"
    }
  },

  "shadows": {
    "note": "Ombres teintées #FF3870 — signature visuelle à conserver absolument",
    "sm": {
      "shadowColor": "#FF3870", "shadowOffset": { "width": 0, "height": 2 },
      "shadowOpacity": 0.10, "shadowRadius": 8, "elevation": 2
    },
    "md": {
      "shadowColor": "#FF3870", "shadowOffset": { "width": 0, "height": 4 },
      "shadowOpacity": 0.15, "shadowRadius": 14, "elevation": 5
    },
    "lg": {
      "shadowColor": "#FF3870", "shadowOffset": { "width": 0, "height": 8 },
      "shadowOpacity": 0.22, "shadowRadius": 24, "elevation": 10
    },
    "fab": {
      "shadowColor": "#FF3870", "shadowOffset": { "width": 0, "height": 6 },
      "shadowOpacity": 0.20, "shadowRadius": 14, "elevation": 8
    }
